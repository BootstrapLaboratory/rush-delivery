---
const base = import.meta.env.BASE_URL;
const docsUrl = `${base}docs/quick-start/github-actions/`;
const actionUrl = `${base}docs/github-action/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Rush Delivery is a Dagger-powered CI delivery framework for Rush monorepos."
    />
    <title>Rush Delivery</title>
  </head>
  <body>
    <canvas id="pipeline-scene" aria-hidden="true"></canvas>
    <header class="site-header">
      <a class="brand" href={base}>Rush Delivery</a>
      <nav aria-label="Primary navigation">
        <a href={docsUrl}>Quick Start</a>
        <a href={actionUrl}>GitHub Action</a>
        <a href="https://github.com/BootstrapLaboratory/rush-delivery">GitHub</a>
      </nav>
    </header>
    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Dagger module for Rush releases</p>
          <h1>Rush Delivery</h1>
          <p class="lede">
            One release path for Rush monorepos: detect affected targets, build,
            package, and deploy through Dagger with metadata kept in the project
            that owns the product.
          </p>
          <div class="actions">
            <a class="button primary" href={docsUrl}>Quick Start <span>-></span></a>
            <a class="button secondary" href={actionUrl}>Use The Action</a>
          </div>
        </div>
        <div class="terminal-panel" aria-label="Rush Delivery workflow summary">
          <div class="panel-bar">
            <span></span><span></span><span></span>
          </div>
          <pre><code>uses: BootstrapLaboratory/rush-delivery@v0.3.4
with:
  dry-run: "false"
  runtime-file-map: |
    creds.json=>gcp-credentials.json
  deploy-env: |
    GCP_PROJECT_ID=production</code></pre>
        </div>
      </section>

      <section class="trust-strip" aria-label="Workflow capabilities">
        <div>
          <strong>Git source</strong>
          <span>No caller repo mount required in CI.</span>
        </div>
        <div>
          <strong>Runtime files</strong>
          <span>Late-bound deploy credentials stay out of source.</span>
        </div>
        <div>
          <strong>Rush aware</strong>
          <span>Plans build/package/deploy from project metadata.</span>
        </div>
      </section>

      <section class="details">
        <div>
          <p class="eyebrow">Two ways to run</p>
          <h2>Use the action in CI, keep the module everywhere else.</h2>
        </div>
        <div class="feature-grid">
          <article>
            <h3>GitHub Action</h3>
            <p>
              Cleans up Dagger installation, deploy env writing, runtime file
              bundling, source defaults, and the long workflow call.
            </p>
          </article>
          <article>
            <h3>Dagger CLI</h3>
            <p>
              Call the same module directly for local tests, other CI providers,
              and lower-level stage debugging.
            </p>
          </article>
          <article>
            <h3>Project metadata</h3>
            <p>
              Keep deploy scripts, workspace mounts, runtime env, package targets,
              cache providers, and service order with the product repo.
            </p>
          </article>
        </div>
      </section>
    </main>
    <script>
      const canvas = document.getElementById(
        "pipeline-scene",
      ) as HTMLCanvasElement | null;
      if (canvas === null) {
        throw new Error("Pipeline scene canvas was not found.");
      }

      const scene = canvas;
      const context = scene.getContext("2d");
      if (context === null) {
        throw new Error("Pipeline scene 2D context was not available.");
      }
      const ctx = context;
      const palette = {
        ink: "rgba(15, 23, 42, 0.18)",
        line: "rgba(20, 184, 166, 0.42)",
        packet: "rgba(245, 158, 11, 0.82)",
        node: "rgba(255, 255, 255, 0.84)",
        nodeStroke: "rgba(20, 184, 166, 0.32)",
      };

      let width = 0;
      let height = 0;
      let pixelRatio = 1;
      let startedAt = performance.now();

      function resize() {
        pixelRatio = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        scene.width = Math.floor(width * pixelRatio);
        scene.height = Math.floor(height * pixelRatio);
        scene.style.width = `${width}px`;
        scene.style.height = `${height}px`;
        ctx.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
      }

      function pathPoint(progress: number, row: number) {
        const x = width * (0.08 + progress * 0.84);
        const y =
          height * (0.24 + row * 0.16) +
          Math.sin(progress * Math.PI * 2 + row) * 18;
        return { x, y };
      }

      function draw(now: number) {
        const t = (now - startedAt) / 1000;
        ctx.clearRect(0, 0, width, height);
        ctx.fillStyle = "rgba(248, 250, 252, 0.88)";
        ctx.fillRect(0, 0, width, height);

        for (let row = 0; row < 4; row += 1) {
          ctx.beginPath();
          for (let step = 0; step <= 80; step += 1) {
            const point = pathPoint(step / 80, row);
            if (step === 0) ctx.moveTo(point.x, point.y);
            else ctx.lineTo(point.x, point.y);
          }
          ctx.strokeStyle = palette.line;
          ctx.lineWidth = 1.4;
          ctx.stroke();

          for (let node = 0; node < 5; node += 1) {
            const point = pathPoint(node / 4, row);
            ctx.fillStyle = palette.node;
            ctx.strokeStyle = palette.nodeStroke;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.roundRect(point.x - 22, point.y - 12, 44, 24, 6);
            ctx.fill();
            ctx.stroke();
          }

          for (let packet = 0; packet < 3; packet += 1) {
            const progress = (t * 0.08 + packet * 0.32 + row * 0.11) % 1;
            const point = pathPoint(progress, row);
            ctx.fillStyle = palette.packet;
            ctx.beginPath();
            ctx.roundRect(point.x - 10, point.y - 5, 20, 10, 4);
            ctx.fill();
          }
        }

        ctx.fillStyle = palette.ink;
        for (let i = 0; i < 42; i += 1) {
          const x = ((i * 149 + t * 8) % (width + 120)) - 60;
          const y = (i * 83) % height;
          ctx.fillRect(x, y, 1, 1);
        }

        requestAnimationFrame(draw);
      }

      resize();
      requestAnimationFrame(draw);
      window.addEventListener("resize", resize);
    </script>
  </body>
</html>

<style>
  :root {
    color: #172033;
    background: #f8fafc;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    font-synthesis: none;
    letter-spacing: 0;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: #172033;
    background:
      linear-gradient(180deg, rgba(248, 250, 252, 0.7), rgba(248, 250, 252, 1)),
      #f8fafc;
  }

  #pipeline-scene {
    position: fixed;
    inset: 0;
    z-index: -1;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 20px 0;
  }

  .brand {
    color: #172033;
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
    font-size: 0.95rem;
  }

  nav a {
    color: #334155;
    text-decoration: none;
  }

  nav a:hover {
    color: #0f766e;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.85fr);
    align-items: center;
    gap: clamp(28px, 6vw, 88px);
    width: min(1120px, calc(100% - 32px));
    min-height: 76svh;
    margin: 0 auto;
    padding: clamp(44px, 8vw, 92px) 0 clamp(36px, 5vw, 64px);
  }

  .eyebrow {
    margin: 0 0 12px;
    color: #0f766e;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    letter-spacing: 0;
  }

  h1 {
    margin: 0;
    max-width: 720px;
    color: #0f172a;
    font-size: clamp(3.4rem, 9vw, 7.4rem);
    line-height: 0.92;
  }

  .lede {
    max-width: 660px;
    margin: 28px 0 0;
    color: #334155;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 1px solid #0f766e;
    border-radius: 6px;
    padding: 11px 16px;
    font-weight: 800;
    text-decoration: none;
  }

  .button.primary {
    color: #ffffff;
    background: #0f766e;
  }

  .button.secondary {
    color: #0f766e;
    background: rgba(255, 255, 255, 0.72);
  }

  .terminal-panel {
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 80px rgba(15, 23, 42, 0.14);
    overflow: hidden;
  }

  .panel-bar {
    display: flex;
    gap: 8px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    padding: 14px;
  }

  .panel-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .panel-bar span:nth-child(2) {
    background: #f59e0b;
  }

  .panel-bar span:nth-child(3) {
    background: #64748b;
  }

  pre {
    margin: 0;
    padding: 22px;
    overflow: auto;
    color: #0f172a;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .trust-strip,
  .details {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .trust-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(15, 23, 42, 0.1);
  }

  .trust-strip div,
  .feature-grid article {
    background: rgba(255, 255, 255, 0.78);
  }

  .trust-strip div {
    padding: 20px;
  }

  .trust-strip strong,
  .trust-strip span {
    display: block;
  }

  .trust-strip strong {
    color: #0f172a;
  }

  .trust-strip span {
    margin-top: 6px;
    color: #475569;
    line-height: 1.55;
  }

  .details {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: clamp(24px, 5vw, 72px);
    padding: clamp(72px, 10vw, 120px) 0;
  }

  h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.08;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .feature-grid article {
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 8px;
    padding: 22px;
  }

  h3 {
    margin: 0;
    color: #0f172a;
    font-size: 1.1rem;
  }

  .feature-grid p {
    margin: 10px 0 0;
    color: #475569;
    line-height: 1.65;
  }

  @media (max-width: 820px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      flex-wrap: wrap;
    }

    .hero,
    .details {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 48px;
    }

    .trust-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
