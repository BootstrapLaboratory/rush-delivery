{
  // Docusaurus' shared tsconfig currently sets compilerOptions.baseUrl,
  // which TypeScript 6 reports as deprecated in editors. When Docusaurus
  // removes that option upstream, this local copy can go back to:
  // "extends": "@docusaurus/tsconfig"
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Docusaurus",
  "docs": "https://docusaurus.io/docs/typescript-support",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true
  }
}
